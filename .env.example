# Frontend Environment Variables

# Smart Contract Deployment
# After running: npx hardhat run scripts/deploy.ts --network polygonAmoy
# Copy the contract address from the deployment output below:
VITE_REACT_APP_CONTRACT_ADDRESS=

# Web3.Storage API Token (optional - for IPFS uploads)
# Get from: https://console.web3.storage (fully free tier)
VITE_WEB3_STORAGE_TOKEN=

# Backend API Endpoint
VITE_API_URL=http://localhost:3001

# Supabase Configuration (for backend database/auth)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
