PORT=3001
NODE_ENV=development

# Supabase (Create project at https://supabase.com - FREE)
# Instructions:
# 1. Go to https://supabase.com
# 2. Create account (free)
# 3. Create new project
# 4. Go to Settings > API
# 5. Copy values below
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc... (keep this secret!)

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_min_32_chars_long_please_use_random

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Polygon RPC (for blockchain verification)
POLYGON_RPC_URL=https://rpc-amoy.polygon.technology
